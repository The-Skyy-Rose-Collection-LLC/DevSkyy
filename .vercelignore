# =============================================================================
# DevSkyy .vercelignore - Production Deployment
# =============================================================================
# This file excludes non-essential files from Vercel deployment.
# Vercel has a 15,000 file limit. Our repo has 140k+ files without this.

# Node modules - CRITICAL (npm install runs on Vercel)
node_modules
**/node_modules
frontend/node_modules

# Python Virtual Environments - CRITICAL
.venv
.venv-*
**/.venv-*
venv
env
.env.local
*.egg-info
*.egg

# Python Cache
__pycache__
**/__pycache__
*.py[cod]
*$py.class
.Python
*.so

# Mypy Cache - CRITICAL (23k+ files)
.mypy_cache
**/.mypy_cache
.pytest_cache
**/.pytest_cache
.ruff_cache
**/.ruff_cache

# Build Artifacts
.next
frontend/.next
dist
build
*.egg-info
.eggs

# Git (includes large pack files)
.git
.github
.gitattributes

# Serena cache (large pkl files)
.serena
**/.serena

# Assets folder (large media files)
assets

# Non-frontend top-level directories — none of these are referenced by the
# Next.js build (`cd frontend && npm install && npx next build`). They include
# the Python pipeline, agent code, the WordPress theme, 3D experiments, and
# render outputs. Cumulative weight: ~4 GB. Each contains files >10MB that
# trigger Vercel's per-blob upload cap (renders/3d/*.glb, source PNGs, GIFs,
# ZIP archives, native shared libraries from secondary venvs, etc.).
/skyyrose
/agents
/TRELLIS.2
/claude-context
/editorial-staging
/renders
# wordpress-theme excluded EXCEPT the single SOT catalog CSV that
# frontend/lib/catalog.ts reads at build+runtime. Re-include only that file —
# NOT the whole data/ dir (which carries generator scripts, dossiers, and
# authoring notes with no place in the deployed Vercel artifact).
# (gitignore semantics: re-including a file under an excluded dir needs the /* ladder)
/wordpress-theme/*
!/wordpress-theme/skyyrose-flagship
/wordpress-theme/skyyrose-flagship/*
!/wordpress-theme/skyyrose-flagship/data
/wordpress-theme/skyyrose-flagship/data/*
!/wordpress-theme/skyyrose-flagship/data/skyyrose-catalog.csv
/source-products
/brand-assets
/cerebrum
/skyyrose-redesign
/.claude
/.cursor
/.ralph
/.wolf
/.husky
/.planning
/.openwolf
# data excluded EXCEPT sot-images.json — frontend/lib/sot-images.ts reads data/sot-images.json
/data/*
!/data/sot-images.json
/eval
/knowledge-base
/orchestration
/pipelines
/llm
/database
/security
/services
/api
/core
/conversation_pipeline
/mcp_servers

# Vercel local build output
.vercel/output

# Development & Testing
staging
tests
scripts
dev

# Documentation (regenerated)
docs/reports
docs/runbooks

# Docker (not needed for Vercel)
docker
docker-compose*.yml
Dockerfile*

# IDE & Editor
.idea
.vscode
*.swp
*.swo
*~
.DS_Store

# Logs and temp files
*.log
logs
*.tmp
*.temp
tmp
temp

# Archives
*.zip
*.tar.gz
*.tar
*.rar
*.7z

# Large assets (if any)
*.mp4
*.mov
*.avi
generated_assets

# Coverage reports
htmlcov
.coverage
coverage.xml
*.cover

# Jupyter notebooks
.ipynb_checkpoints
*.ipynb

# OS files
Thumbs.db
.DS_Store

# Lock files — keep frontend/package-lock.json for npm, ignore pnpm
pnpm-lock.yaml
yarn.lock
poetry.lock
Pipfile.lock
