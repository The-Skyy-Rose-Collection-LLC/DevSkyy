      "agents": ["deploy-and-verify", "wp-code-simplifier"],
      "plugins": [],
      "workflow": "skyyrose-dev-team"
    },
    {
      "name": "frontend",
      "regex": "\\b(next\\.?js|react|tsx|jsx|tailwind|vercel|dashboard|frontend|component|shadcn|nextjs)\\b",
