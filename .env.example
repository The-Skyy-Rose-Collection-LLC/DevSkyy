# DevSkyy Environment Configuration Template
# Copy this file to .env and replace with actual values
# NEVER commit .env to git - it's in .gitignore

# =============================================================================
# API KEYS - Replace with your actual keys
# =============================================================================

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API
OPENAI_API_KEY=sk-your-key-here

# Hugging Face
HUGGING_FACE_TOKEN=hf_your_token_here

# =============================================================================
# DATABASE
# =============================================================================

DATABASE_URL=postgresql://user:password@localhost:5432/devskyy
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# SECURITY
# =============================================================================

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-secret-key-min-32-characters-long
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption Key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-encryption-key-here

# =============================================================================
# WORDPRESS INTEGRATION
# =============================================================================

# Skyy Rose Collection WordPress Site
WORDPRESS_SITE_URL=https://your-site.com
WORDPRESS_USERNAME=your-username
WORDPRESS_PASSWORD=your-password
WORDPRESS_APPLICATION_PASSWORD=your-app-password-here
WORDPRESS_API_KEY=your-wordpress-api-key

# =============================================================================
# WOOCOMMERCE INTEGRATION
# =============================================================================

# WooCommerce Store URL (including https://)
WOOCOMMERCE_URL=https://your-store.com

# WooCommerce REST API credentials (generate from WooCommerce > Settings > Advanced > REST API)
WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WooCommerce Service Configuration (Optional - defaults shown)
WOOCOMMERCE_BATCH_SIZE=10
WOOCOMMERCE_MAX_RETRIES=3

# =============================================================================
# GOOGLE SHEETS INTEGRATION
# =============================================================================

# Path to Google service account credentials JSON file
# Generate from: https://console.cloud.google.com/apis/credentials
GOOGLE_CREDENTIALS_PATH=/path/to/google-credentials.json

# =============================================================================
# TELEGRAM NOTIFICATIONS
# =============================================================================

# Telegram Bot Configuration (Optional - for product import notifications)
# Create a bot via @BotFather and get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# =============================================================================
# AI MODEL CONFIGURATION
# =============================================================================

# AI Model Selection (Optional - defaults shown)
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4

# AI Generation Parameters (Optional - defaults shown)
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=500

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=False

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Trusted Hosts (comma-separated)
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
