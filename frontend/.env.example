# DevSkyy Dashboard — Environment Variables
# Copy to .env.local: cp .env.example .env.local

# ─── API Connection (required) ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Authentication (required) ────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── WordPress Integration (optional) ────────────────
WORDPRESS_URL=https://skyyrose.co
WOOCOMMERCE_KEY=ck_your_consumer_key_here
WOOCOMMERCE_SECRET=cs_your_consumer_secret_here
NEXT_PUBLIC_WORDPRESS_URL=https://skyyrose.co

# ─── WP↔Dashboard wiring core (WS7, server-only) ──────
WP_BASE_URL=https://skyyrose.co
WP_APP_USER=devskyy-service
WP_APP_PASSWORD=            # wp-admin -> profile -> Application Passwords
WC_CONSUMER_KEY=            # ck_… WooCommerce -> Settings -> Advanced -> REST API (Read/Write)
WC_CONSUMER_SECRET=         # cs_…
WP_WEBHOOK_SECRET=          # HMAC secret for /api/webhooks/woocommerce (generate: openssl rand -hex 32)
REVALIDATE_SECRET=          # reserved for a future manual /api/revalidate trigger (not consumed yet)

# ─── Feature Flags ───────────────────────────────────
NEXT_PUBLIC_SITE_NAME=SkyyRose
NEXT_PUBLIC_ENABLE_ROUND_TABLE=true

# ─── External Services (optional) ────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# FACEBOOK_ACCESS_TOKEN=
# GOOGLE_API_KEY=
