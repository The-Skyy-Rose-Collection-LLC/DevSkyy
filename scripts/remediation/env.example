# SkyyRose dashboard <-> WordPress wiring (SKYYROSE_LAUNCH_NIGHT_SPEC_V2.md §C2)
# Copy to .env (git-ignored, chmod 600). All server-side — NEVER prefix with NEXT_PUBLIC_.
# Populate via: python3 scripts/remediation/setup_credentials.py
WP_BASE_URL=https://skyyrose.co
WP_APP_USER=devskyy-service
WP_APP_PASSWORD=            # wp-admin -> profile -> Application Passwords
WC_CONSUMER_KEY=            # ck_… WooCommerce -> Settings -> Advanced -> REST API (Read/Write)
WC_CONSUMER_SECRET=         # cs_…
WP_WEBHOOK_SECRET=          # auto-generated by setup script (HMAC for Woo webhooks)
REVALIDATE_SECRET=          # auto-generated by setup script (Next.js on-demand revalidation)
