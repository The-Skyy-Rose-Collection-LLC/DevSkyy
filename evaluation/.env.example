# DevSkyy - evaluation/ domain (QC judge / RenderFidelityEvaluator) (TEMPLATE — uncomment & fill; safe to commit)
# AUTO-GENERATED per-domain env. Real values injected at runtime (operator never sees them).
# git-ignored. UNFILLED keys are COMMENTED so they never shadow code-side os.getenv(K, default).
# To set one: uncomment and add the value. Load: `set -a; source <file>; set +a` or load_dotenv(<file>).


# Judge provider credential - ClaudeJudge default (REQUIRED: ANTHROPIC_API_KEY)
# ANTHROPIC_API_KEY=

# Alternate judge providers (QC_JUDGE_PROVIDER=openai|gemini)
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=
# GEMINI_API_KEY=

# QC judge tuning - consumed by scripts/oai_render QC layer that drives the judge (optional; have defaults)
# QC_JUDGE_PROVIDER=
# QC_JUDGE_MODEL=
# QC_JUDGE_MODEL_ANTHROPIC=
# QC_JUDGE_DETAIL=
# QC_JUDGE_MAX_OUTPUT_TOKENS=
