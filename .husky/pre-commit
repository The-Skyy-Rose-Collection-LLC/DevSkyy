#!/usr/bin/env sh
# Pre-commit: lint, type-check, syntax, and test gates
# Delegates file-level checks to lint-staged, runs whole-project tools conditionally.

# Activate project venv if available (ruff, mypy, pytest live here)
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo '.')"
if [ -f "$REPO_ROOT/.venv/bin/activate" ]; then
  . "$REPO_ROOT/.venv/bin/activate"
fi

# File-level checks via lint-staged (ruff, black, isort, eslint, tsc, php -l)
npx lint-staged

# Whole-project tools that can't run per-file via lint-staged

# mypy: whole-project type check when Python files are staged
if git diff --cached --name-only --diff-filter=ACMR | grep -q '\.py$'; then
  if command -v mypy >/dev/null 2>&1; then
    echo "Running mypy type check..."
    # --exclude belt-and-suspenders: keeps git worktree duplicates AND the gitignored
    # autonomous-agent scratch dir (my_project/) out of the discovery scan even if
    # mypy.ini exclude filtering runs too late. gitignore is invisible to mypy's walk.
    mypy . --ignore-missing-imports --exclude '(\.claude/|my_project/|prototypes/|skyyrose-suite/|devskyy-sdk-app/)'
  fi
fi

# Fast unit tests on staged Python files
if git diff --cached --name-only --diff-filter=ACMR | grep -q '\.py$'; then
  if command -v pytest >/dev/null 2>&1 && [ -d "$REPO_ROOT/tests/unit" ]; then
    echo "Running fast unit tests..."
    pytest tests/unit/ -x -q
  fi
fi

# Catalog consistency gate: staged files touching the catalog CSV, logo registry,
# or the readers that consume them must pass validate_catalog_consistency.py.
# Ports the file-pattern trigger of the orphaned .git/hooks/pre-commit (dead since
# core.hooksPath=.husky/_ moved Git off it — see SOT.md "Known dead hook"), so the
# gate is actually live again. Skip: SKIP_CATALOG_VALIDATE=1 git commit
CATALOG_PATTERN='wordpress-theme/skyyrose-flagship/data/skyyrose-catalog\.csv|wordpress-theme/skyyrose-flagship/data/logo-registry\.json|wordpress-theme/skyyrose-flagship/data/product-similarities\.json|skyyrose/elite_studio/sku_resolver\.py|skyyrose/elite_studio/logo_registry\.py|skyyrose/elite_studio/commerce\.py|scripts/validate_catalog_consistency\.py|scripts/sync_catalog_downstream\.py'
if [ "${SKIP_CATALOG_VALIDATE:-0}" != "1" ] \
   && git diff --cached --name-only --diff-filter=ACMR | grep -qE "$CATALOG_PATTERN"; then
  PY="$REPO_ROOT/.venv/bin/python3"; [ -x "$PY" ] || PY="python3"
  if command -v "$PY" >/dev/null 2>&1; then
    echo "Running catalog consistency validator (staged catalog files changed)..."
    "$PY" "$REPO_ROOT/scripts/validate_catalog_consistency.py" || exit 1
  fi
fi

# Freshness guard: derived files (SOT sot.json/design-tokens, theme .min,
# theme version, retired-master refs) must not be committed stale. Scoped to
# staged files, so it is a no-op unless you touched a source whose derived file
# drifted. Fix with: bash scripts/freshness-guard.sh --fix
if [ -f "$REPO_ROOT/scripts/freshness-guard.sh" ]; then
  bash "$REPO_ROOT/scripts/freshness-guard.sh" || exit 1
fi
