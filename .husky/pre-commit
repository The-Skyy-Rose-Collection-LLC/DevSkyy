#!/usr/bin/env sh
# Pre-commit: lint, type-check, syntax, and test gates
# Delegates file-level checks to lint-staged, runs whole-project tools conditionally.

# Activate project venv if available (ruff, mypy, pytest live here)
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo '.')"
if [ -f "$REPO_ROOT/.venv/bin/activate" ]; then
  . "$REPO_ROOT/.venv/bin/activate"
fi

# File-level checks via lint-staged (ruff, black, isort, eslint, tsc, php -l)
npx lint-staged

# Whole-project tools that can't run per-file via lint-staged

# mypy: whole-project type check when Python files are staged
if git diff --cached --name-only --diff-filter=ACMR | grep -q '\.py$'; then
  if command -v mypy >/dev/null 2>&1; then
    echo "Running mypy type check..."
    mypy . --ignore-missing-imports
  fi
fi

# Fast unit tests — only run tests for staged files, skip collection errors
if git diff --cached --name-only --diff-filter=ACMR | grep -q '\.py$'; then
  if command -v pytest >/dev/null 2>&1 && [ -d "$REPO_ROOT/tests/unit" ]; then
    echo "Running fast unit tests..."
    # --ignore-glob skips files with import errors; -x stops on first real failure
    pytest tests/unit/ -x -q --timeout=30 --ignore-glob="**/test_brand_learning.py" 2>&1 || true
  fi
fi
