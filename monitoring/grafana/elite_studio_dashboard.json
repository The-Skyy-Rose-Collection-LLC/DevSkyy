{
  "id": null,
  "uid": "elite-studio-v1",
  "title": "Elite Studio Pipeline",
  "description": "SkyyRose Elite Studio image pipeline — throughput, latency, cost, quality, and A/B comparison",
  "schemaVersion": 36,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "job_status",
        "label": "Job Status",
        "type": "custom",
        "current": {
          "text": "All",
          "value": ""
        },
        "options": [
          { "text": "All",     "value": "",        "selected": true },
          { "text": "Success", "value": "success", "selected": false },
          { "text": "Error",   "value": "error",   "selected": false },
          { "text": "Skipped", "value": "skipped", "selected": false }
        ],
        "query": "All,success,error,skipped",
        "multi": false,
        "includeAll": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Throughput — Jobs per Minute",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(elite_studio_jobs_total{status=~\"$job_status\"}[1m]) * 60",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Stage Latency — p50 / p95 / p99",
      "type": "heatmap",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "options": {
        "calculate": false,
        "color": {
          "mode": "scheme",
          "scheme": "Oranges"
        },
        "yAxis": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(elite_studio_stage_duration_s_bucket[5m])) by (le, stage))",
          "legendFormat": "p50 {{stage}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(elite_studio_stage_duration_s_bucket[5m])) by (le, stage))",
          "legendFormat": "p95 {{stage}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(elite_studio_stage_duration_s_bucket[5m])) by (le, stage))",
          "legendFormat": "p99 {{stage}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "Cost Breakdown — Cumulative USD by Provider",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [
        {
          "expr": "elite_studio_cost_dollars_total",
          "legendFormat": "{{provider}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "QC Score Distribution",
      "type": "histogram",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "#B76E79" }
        }
      },
      "options": {
        "bucketSize": "auto",
        "fillOpacity": 80
      },
      "targets": [
        {
          "expr": "sum(rate(elite_studio_qc_score_bucket[5m])) by (le)",
          "legendFormat": "QC Score",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Queue Depth",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0  },
              { "color": "yellow", "value": 50 },
              { "color": "red",    "value": 200 }
            ]
          },
          "min": 0,
          "max": 500
        }
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "elite_studio_queue_depth",
          "legendFormat": "Queue Depth",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "Error Rate — % Failed",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "fixed", "fixedColor": "#DC143C" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0    },
              { "color": "yellow", "value": 0.05 },
              { "color": "red",    "value": 0.15 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(elite_studio_jobs_total{status=\"error\"}[5m]) / clamp_min(rate(elite_studio_jobs_total[5m]), 1)",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "A/B Winner — Mean QC Score by Provider",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "color": { "mode": "continuous-GrYlRd" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0   },
              { "color": "yellow", "value": 0.6 },
              { "color": "green",  "value": 0.8 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(elite_studio_qc_score_bucket[1h])) by (le))",
          "legendFormat": "Median QC Score",
          "refId": "A",
          "instant": true
        }
      ]
    }
  ]
}
