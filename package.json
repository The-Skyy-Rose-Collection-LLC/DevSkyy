  "scripts": {
    "build": "tsc --project config/typescript/tsconfig.json",
    "build:watch": "tsc --project config/typescript/tsconfig.json --watch",
    "dev": "nodemon --exec \"node --loader ts-node/esm src/index.ts\"",
    "start": "node dist/index.js",
    "test": "jest --config config/testing/jest.config.cjs",
    "test:watch": "jest --config config/testing/jest.config.js --watch",
    "test:coverage": "jest --config config/testing/jest.config.js --coverage",
    "test:ci": "jest --config config/testing/jest.config.js --ci --coverage --watchAll=false",
    "lint": "eslint src/**/*.{ts,tsx,js,jsx}",
    "lint:fix": "eslint src/**/*.{ts,tsx,js,jsx} --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx}\" \"*.{json,md}\"",
    "type-check": "tsc --project config/typescript/tsconfig.json --noEmit",
    "clean": "rm -rf dist coverage",
    "prepare": "npm run build",
    "precommit": "npm run lint && npm run type-check && npm run test:ci",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "deps:update": "npm update",
    "deps:check": "npm outdated",
    "demo:collections": "echo '🌹 SkyyRose Collection 3D Experiences Demo' && echo 'Available collections: black_rose, signature, love_hurts, showroom, runway' && echo 'Run: npm run demo:black-rose | demo:signature | demo:love-hurts | demo:showroom | demo:runway'",
    "demo:black-rose": "npx vite serve --open --config config/vite/demo.config.ts -- --collection=black_rose",
    "demo:signature": "npx vite serve --open --config config/vite/demo.config.ts -- --collection=signature",
    "demo:love-hurts": "npx vite serve --open --config config/vite/demo.config.ts -- --collection=love_hurts",
    "demo:showroom": "npx vite serve --open --config config/vite/demo.config.ts -- --collection=showroom",
    "demo:runway": "npx vite serve --open --config config/vite/demo.config.ts -- --collection=runway",
    "test:collections": "jest --config config/testing/jest.config.cjs --testPathPatterns=collections --no-coverage"
  },
