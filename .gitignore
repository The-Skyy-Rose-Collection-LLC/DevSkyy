# Third-party AI coding-assistant config dirs. Each contains ONLY symlinks
# mirroring skills from .agents/skills/ (gitignored) — so they are DEAD on a
# fresh clone. Untracked in the repo-cleanup pass; kept on disk locally.
.adal/
.augment/
.bob/
.codebuddy/
.commandcode/
.continue/
.cortex/
.crush/
.factory/
.goose/
.iflow/
.junie/
.kilocode/
.kiro/
.kode/
.mcpjam/
.mux/
.neovate/
.openhands/
.pi/
.pochi/
.qoder/
.qwen/
.roo/
.trae/
.vibe/
.windsurf/
.zencoder/

# OpenWolf session-local state (churns every action — not content, ignore)
.wolf/memory.md
.wolf/token-ledger.json
.wolf/hooks/_session.json
.wolf/claude-mem-digest.md

# claude-mem per-folder context injection → CLAUDE.local.md (FOLDER_USE_LOCAL_MD=true).
# Claude Code still loads it as local context; git ignores it so the sync gathers
# info without churning tracked CLAUDE.md files (matches at any depth, no slash).
CLAUDE.local.md

# Prototype scratch tree (61MB; founder-picked variants are PORTED into the theme,
# the scratch itself is not tracked). Also avoids duplicate build-standalone.py
# module collisions in mypy. Un-ignore deliberately if a variant must be preserved.
prototypes/

# Root-level Jupyter notebooks (belong in a /notebooks/ dir, not repo root)
/*.ipynb

# Immersive test renders (regenerable)
wordpress-theme/skyyrose-flagship/assets/images/immersive/test/
scripts/nano-banana-composite-results.json

# Vendored third-party repos (cloned via git, not authored here).
# Track the scaffolding (README + .gitignore) so contributors can bootstrap.
vendor/*
!vendor/.gitignore
!vendor/README.md

